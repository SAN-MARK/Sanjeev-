# Environment Configuration for Sanjeev M Portfolio Backend

# Server Configuration
NODE_ENV=development
PORT=3000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Email Configuration (Gmail)
# To use Gmail with Node.js:
# 1. Enable 2-Step Verification in your Google Account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-character password below

EMAIL_USER=iamheresanjeev@gmail.com
EMAIL_PASSWORD=your_16_character_app_password_here

# Alternative Email Services:
# For SendGrid: USE_SENDGRID=true, SENDGRID_API_KEY=your_key
# For Mailgun: USE_MAILGUN=true, MAILGUN_API_KEY=your_key, MAILGUN_DOMAIN=your_domain

# Database (for future use)
# MONGODB_URI=mongodb://localhost:27017/sanjeev-portfolio
# DATABASE_NAME=sanjeev-portfolio

# API Keys (optional, for future integrations)
# GITHUB_TOKEN=your_github_token
# LINKEDIN_TOKEN=your_linkedin_token
